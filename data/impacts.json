{
  "impacts": [
    {
      "id": 1,
      "name": "Coûts de mise en œuvre de la SfN",
      "description": "Coûts d'investissement, de gestion, d'exploitation et de maintenance."
    },
    {
      "id": 2,
      "name": "Pertes d'activités économiques",
      "description": "Pertes de revenus et baisse d'activité résultant directement de la mise en œuvre de la SfN."
    },
    {
      "id": 3,
      "name": "Impacts négatifs générés par des travaux",
      "description": "Impacts environnementaux temporaires générés par les travaux nécessaires à la mise en œuvre de la SfN."
    },
    {
      "id": 4,
      "name": "Impacts négatifs sur les services écosystémiques",
      "description": "Impacts négatifs potentiels sur les services écosystémiques résultant des modifications de milieux, d’usages ou de modes de gestion."
    },
    {
      "id": 5,
      "name": "Contribution aux retombées économiques pour le territoire",
      "description": "Soutien à l’activité économique du territoire, notamment via les impacts directs, indirects et induits."
    },
    {
      "id": 6,
      "name": "Régulation des crues et inondations",
      "description": "Impacts résultant de l’atténuation des risques de crues et d’inondations."
    },
    {
      "id": 7,
      "name": "Atténuation des épisodes de sécheresse",
      "description": "Impacts résultant de l’atténuation de l’intensité et de la fréquence des épisodes de sécheresse."
    },
    {
      "id": 8,
      "name": "Atténuation des hausses de températures",
      "description": "Impacts résultant de l’atténuation des fortes chaleurs et canicules, notamment à l’échelle locale."
    },
    {
      "id": 9,
      "name": "Amélioration de la qualité de l’eau",
      "description": "Impacts résultant de l’amélioration de la qualité des eaux et du bon fonctionnement des écosystèmes aquatiques."
    },
    {
      "id": 10,
      "name": "Stockage du carbone",
      "description": "Séquestration du carbone et contribution à l’atténuation des émissions de gaz à effet de serre."
    },
    {
      "id": 11,
      "name": "Impact sur les productions primaires",
      "description": "Effets sur les productions agricoles, forestières et piscicoles."
    },
    {
      "id": 12,
      "name": "Activités récréatives et culturelles",
      "description": "Développement d’activités récréatives, culturelles, éducatives et touristiques."
    },
    {
      "id": 13,
      "name": "Amélioration du cadre de vie",
      "description": "Amélioration du paysage, des espaces de vie, de la santé et du bien-être."
    },
    {
      "id": 14,
      "name": "Amélioration du patrimoine naturel (biodiversité)",
      "description": "Amélioration de la qualité des sites, espaces et espèces naturels, et de la biodiversité."
    },
    {
      "id": 15,
      "name": "Amélioration de la résilience du territoire",
      "description": "Renforcement de la capacité du territoire à anticiper, absorber et surmonter les aléas."
    }
  ],
